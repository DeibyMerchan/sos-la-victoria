---
interface Props {
  latitud: number;
  longitud: number;
  nombre: string;
}

const { latitud, longitud, nombre } = Astro.props;
---

<div class="bg-white rounded-2xl shadow-md overflow-hidden">
  <div id="mapa-refugio" style="height: 250px; width: 100%;" data-lat={latitud} data-lng={longitud} data-nombre={nombre}>
  </div>
  <div class="px-4 py-2 text-center">
    <a href={`https://www.google.com/maps?q=${latitud},${longitud}`} target="_blank"
       class="text-blue-600 text-sm font-medium hover:underline">
      Ver en Google Maps
    </a>
  </div>
</div>

<script>
  import L from "leaflet";
  import "leaflet/dist/leaflet.css";

  const mapa = document.getElementById("mapa-refugio");
  if (mapa) {
    const lat = parseFloat(mapa.dataset.lat || "0");
    const lng = parseFloat(mapa.dataset.lng || "0");
    const nombre = mapa.dataset.nombre || "Refugio";

    if (lat && lng) {
      const map = L.map(mapa).setView([lat, lng], 15);

      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        maxZoom: 19,
      }).addTo(map);

      L.marker([lat, lng])
        .addTo(map)
        .bindPopup(`<b>${nombre}</b>`)
        .openPopup();
    }
  }
</script>
