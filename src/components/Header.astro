        Tel: {telefonoDisplay}
      </a>
    ) : null}
  </div>
</nav>

<!-- SOS Modal -->
<div id="sos-modal" class="fixed inset-0 bg-black bg-opacity-60 z-50 hidden flex items-end sm:items-center justify-center">
  <div class="bg-white rounded-t-2xl sm:rounded-2xl w-full sm:max-w-sm p-6 shadow-2xl animate-slide-up">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold text-red-700">Emergencia SOS</h2>
      <button id="sos-modal-close" class="text-gray-400 hover:text-gray-600 text-2xl" aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <p class="text-gray-600 mb-5 text-sm">Selecciona cómo quieres contactar asistencia de emergencia:</p>
    <div class="space-y-3">
      <a id="sos-call" href="tel:{telefono}" class="flex items-center gap-3 bg-green-500 text-white px-4 py-3 rounded-xl font-medium hover:bg-green-600 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Llamar
      </a>
      <a id="sos-whatsapp" href={whatsapp ? `https://wa.me/${whatsapp.replace(/\D/g, '')}?text=Emergencia%20SOS%20La%20Victoria%20-%20Necesito%20ayuda` : '#'} target="_blank" class="flex items-center gap-3 bg-emerald-500 text-white px-4 py-3 rounded-xl font-medium hover:bg-emerald-600 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 1.637 6.016L0 24l6.152-1.604A11.958 11.958 0 0 0 11.944 24 12 12 0 0 0 24 12 12 12 0 0 0 11.944 0zm0 21.962a9.924 9.924 0 0 1-5.063-1.386l-.363-.216-3.65.952.974-3.556-.237-.378A9.926 9.926 0 0 1 2.038 12 9.906 9.906 0 0 1 11.944 2.1 9.906 9.906 0 0 1 21.85 12a9.906 9.906 0 0 1-9.906 9.962z"/>
          <path d="M17.15 14.212c-.163-.082-.966-.476-1.115-.531-.15-.055-.26-.082-.368.082-.109.164-.423.531-.518.64-.096.108-.191.122-.354.04-.163-.081-.689-.254-1.313-.81a4.83 4.83 0 0 1-.908-1.128c-.095-.163-.01-.252.072-.333.074-.074.163-.19.245-.286.081-.095.108-.163.163-.272.054-.109.027-.204-.014-.286-.04-.081-.368-.887-.504-1.215-.133-.32-.268-.276-.368-.281-.095-.005-.204-.006-.313-.006-.11 0-.286.04-.436.204-.15.163-.572.559-.572 1.363 0 .804.586 1.581.668 1.69.081.109 1.154 1.762 2.796 2.471 1.642.71 1.642.473 1.938.444.296-.03.966-.395 1.102-.777.136-.381.136-.708.095-.777-.04-.068-.15-.109-.313-.19z"/>
        </svg>
        WhatsApp
      </a>
      <button id="sos-location" class="w-full flex items-center gap-3 bg-blue-500 text-white px-4 py-3 rounded-xl font-medium hover:bg-blue-600 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Compartir ubicación
      </button>
    </div>
  </div>
</div>

<script>
  // Menú lateral
  const menuToggle = document.getElementById('menu-toggle');
  const menuClose = document.getElementById('menu-close');
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');

  function openMenu() {
    sidebar?.classList.remove('-translate-x-full');
    overlay?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    sidebar?.classList.add('-translate-x-full');
    overlay?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  menuToggle?.addEventListener('click', openMenu);
  menuClose?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);

  // SOS Modal
  const sosButton = document.getElementById('sos-button');
  const sosModal = document.getElementById('sos-modal');
  const sosModalClose = document.getElementById('sos-modal-close');
  const sosLocation = document.getElementById('sos-location');

  sosButton?.addEventListener('click', (e) => {
    e.preventDefault();
    sosModal?.classList.remove('hidden');
    // Registrar solicitud SOS
    fetch('/api/sos', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ canal: 'whatsapp' })
    }).catch(() => {});
  });

  sosModalClose?.addEventListener('click', () => sosModal?.classList.add('hidden'));
  sosModal?.addEventListener('click', (e) => {
    if (e.target === sosModal) sosModal.classList.add('hidden');
  });

  // Compartir ubicación
  sosLocation?.addEventListener('click', () => {
    if (navigator.geolocation) {
      sosLocation.textContent = 'Obteniendo ubicación...';
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          const url = `https://www.google.com/maps?q=${pos.coords.latitude},${pos.coords.longitude}`;
          const msg = `Emergencia SOS - Mi ubicación: ${url}`;
          const wa = sosButton?.dataset.whatsapp || '';
          if (wa) {
            window.open(`https://wa.me/${wa.replace(/\\D/g, '')}?text=${encodeURIComponent(msg)}`, '_blank');
          }
          fetch('/api/sos', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ canal: 'ubicacion', ubicacion: url })
          }).catch(() => {});
          sosLocation.textContent = 'Compartir ubicación';
          sosModal?.classList.add('hidden');
        },
        () => {
          alert('No se pudo obtener la ubicación. Verifica los permisos del navegador.');
          sosLocation.textContent = 'Compartir ubicación';
        }
      );
    } else {
      alert('Tu navegador no soporta geolocalización.');
    }
  });

  // Cerrar SOS al abrir WhatsApp
  document.getElementById('sos-whatsapp')?.addEventListener('click', () => {
    sosModal?.classList.add('hidden');
  });
  document.getElementById('sos-call')?.addEventListener('click', () => {
    sosModal?.classList.add('hidden');
  });
</script>

<style>
  @keyframes slide-up {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }
  @media (min-width: 640px) {
    @keyframes slide-up {
      from { transform: translateY(20px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
  }
  .animate-slide-up {
    animation: slide-up 0.3s ease-out;
  }
</style>
