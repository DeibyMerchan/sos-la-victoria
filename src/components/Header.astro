---
import { supabase } from "../lib/supabaseClient";

let whatsapp = "";
let telefono = "";
let telefonoDisplay = "N/D";

try {
  const { data: config, error } = await supabase
    .from("configuracion")
    .select("whatsapp, telefono")
    .eq("id", 1)
    .maybeSingle();

  if (!error && config) {
    whatsapp = config.whatsapp || "";
    telefono = config.telefono || "";
    telefonoDisplay = telefono || whatsapp || "N/D";
  }
} catch (_e) {
  // configuración no disponible, se usan valores por defecto
}
---

