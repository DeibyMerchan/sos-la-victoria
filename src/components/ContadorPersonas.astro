<div id="contador" class="bg-white rounded-2xl shadow-md p-6 text-center">
  <p class="text-sm text-gray-500 mb-2">Personas registradas</p>
  <p class="text-4xl font-extrabold text-red-700" id="contador-valor">--</p>
</div>
<script>
  async function load() {
    try {
      const r = await fetch('/api/contador');
      const d = await r.json();
      const el = document.getElementById('contador-valor');
      if (el) el.textContent = d.contador ?? '--';
    } catch (_) {}
  }
  load();
  setInterval(load, 45000);
</script>
