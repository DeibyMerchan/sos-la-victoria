---
interface Props { nombre: string; direccion?: string; ocupacion: number; capacidad: number; latitud?: number; longitud?: number; }
const { nombre, direccion, ocupacion, capacidad, latitud, longitud } = Astro.props;
const pct = capacidad > 0 ? Math.min(100, Math.round((ocupacion / capacidad) * 100)) : 0;
const barColor = pct > 90 ? "bg-red-500" : pct > 60 ? "bg-yellow-500" : "bg-emerald-500";
---

<div class="bg-white rounded-2xl shadow-md p-5">
  <div class="flex items-start gap-3 mb-3">
    <div class="bg-blue-100 p-2.5 rounded-xl flex-shrink-0">
      <svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
    </div>
    <div class="flex-1 min-w-0">
      <h3 class="font-bold text-gray-800 truncate">{nombre}</h3>
      {direccion && <p class="text-xs text-gray-500 mt-0.5 truncate">{direccion}</p>}
    </div>
  </div>
  <div class="flex justify-between text-sm text-gray-600 mb-2">
    <span>Ocupación</span>
    <span class="font-semibold">{ocupacion} / {capacidad}</span>
  </div>
  <div class="w-full bg-gray-200 rounded-full h-3">
    <div class={`h-3 rounded-full transition-all ${barColor}`} style={`width:${pct}%`}></div>
  </div>
  {latitud && longitud ? (
    <a href={`https://www.google.com/maps?q=${latitud},${longitud}`} target="_blank" class="inline-flex items-center gap-1 text-blue-600 text-xs font-medium mt-3 hover:underline">
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      Ver en Google Maps
    </a>
  ) : null}
</div>
