---
import LayoutPublico from "../layouts/LayoutPublico.astro";
import Header from "../components/Header.astro";
import { supabase } from "../lib/supabaseClient";

let noticias: any[] = [];
try { const { data } = await supabase.from("noticias").select("*").order("created_at", { ascending: false }); if (data) noticias = data; } catch (_) {}
---

<LayoutPublico
  title="Noticias y Comunicados | SOS La Victoria"
  description="Noticias y comunicados oficiales sobre la situación humanitaria en La Victoria. Información actualizada sobre ayudas, refugios y operativos de emergencia."
>
  <Header />
  <main class="max-w-lg mx-auto px-4 py-6 pb-10">
    <a href="/" class="text-red-600 text-sm font-medium inline-flex items-center gap-1 mb-4 hover:underline">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg> Volver
    </a>
    <h1 class="text-2xl font-bold text-red-700 mb-6">Noticias</h1>
    {noticias.length === 0 ? <p class="text-center text-gray-400 py-8">No hay noticias.</p> : (
      <div class="space-y-4">
        {noticias.map(n => (
          <article class="bg-white rounded-2xl shadow-md p-5">
            <h3 class="font-bold text-gray-800">{n.titulo}</h3>
            <p class="text-xs text-gray-400 mt-1">{new Date(n.created_at).toLocaleDateString("es-VE", { day: "numeric", month: "long", year: "numeric" })}</p>
            <p class="text-sm text-gray-600 mt-3 leading-relaxed">{n.contenido}</p>
          </article>
        ))}
      </div>
    )}
  </main>
</LayoutPublico>
