---
import LayoutPublico from "../layouts/LayoutPublico.astro";
import Header from "../components/Header.astro";
import { supabase } from "../lib/supabaseClient";

let whatsapp = ""; let telefono = "";
try {
  const { data: c } = await supabase.from("configuracion").select("whatsapp, telefono").eq("id", 1).maybeSingle();
  if (c) { whatsapp = c.whatsapp || ""; telefono = c.telefono || ""; }
} catch (_) {}
const tel = telefono || whatsapp;
---

<LayoutPublico
  title="Números de Emergencia | SOS La Victoria"
  description="Números de teléfono y WhatsApp de Protección Civil, Bomberos y coordinación SOS La Victoria. Contacto directo para emergencias por inundación."
>
  <Header />
  <main class="max-w-lg mx-auto px-4 py-6 pb-10">
    <h1 class="text-2xl font-bold text-red-700 mb-6">Números de Emergencia</h1>
    <div class="space-y-3">
      {[
        { label: "Protección Civil", color: "bg-red-100 text-red-600", icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" },
        { label: "Bomberos", color: "bg-orange-100 text-orange-600", icon: "M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" },
        { label: "Alcaldía de Páez", color: "bg-blue-100 text-blue-600", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
      ].map(e => (
        <div class="bg-white rounded-2xl shadow-md p-4 flex items-center gap-4">
          <div class={`${e.color} p-3 rounded-xl`}><svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={e.icon}/></svg></div>
          <div>
            <p class="font-bold text-gray-800">{e.label}</p>
            {tel && <a href={`tel:${tel}`} class="text-blue-600 font-medium text-lg">{tel}</a>}
          </div>
        </div>
      ))}
      <div class="bg-white rounded-2xl shadow-md p-4 flex items-center gap-4">
        <div class="bg-green-100 p-3 rounded-xl">
          <svg class="h-7 w-7 text-green-600" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 1.637 6.016L0 24l6.152-1.604A11.958 11.958 0 0 0 11.944 24 12 12 0 0 0 24 12 12 12 0 0 0 11.944 0zm0 21.962a9.924 9.924 0 0 1-5.063-1.386l-.363-.216-3.65.952.974-3.556-.237-.378A9.926 9.926 0 0 1 2.038 12 9.906 9.906 0 0 1 11.944 2.1 9.906 9.906 0 0 1 21.85 12a9.906 9.906 0 0 1-9.906 9.962z"/><path d="M17.15 14.212c-.163-.082-.966-.476-1.115-.531-.15-.055-.26-.082-.368.082-.109.164-.423.531-.518.64-.096.108-.191.122-.354.04-.163-.081-.689-.254-1.313-.81a4.83 4.83 0 0 1-.908-1.128c-.095-.163-.01-.252.072-.333.074-.074.163-.19.245-.286.081-.095.108-.163.163-.272.054-.109.027-.204-.014-.286-.04-.081-.368-.887-.504-1.215-.133-.32-.268-.276-.368-.281-.095-.005-.204-.006-.313-.006-.11 0-.286.04-.436.204-.15.163-.572.559-.572 1.363 0 .804.586 1.581.668 1.69.081.109 1.154 1.762 2.796 2.471 1.642.71 1.642.473 1.938.444.296-.03.966-.395 1.102-.777.136-.381.136-.708.095-.777-.04-.068-.15-.109-.313-.19z"/></svg>
        </div>
        <div>
          <p class="font-bold text-gray-800">Coordinación SOS</p>
          <div class="flex gap-4 mt-1">
            {tel && <a href={`tel:${tel}`} class="text-blue-600 font-medium">Llamar</a>}
            {whatsapp && <a href={`https://wa.me/${whatsapp.replace(/\D/g, '')}`} target="_blank" class="text-emerald-600 font-medium">WhatsApp</a>}
          </div>
        </div>
      </div>
    </div>
  </main>
</LayoutPublico>
