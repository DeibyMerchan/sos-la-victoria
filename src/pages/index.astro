---
import LayoutPublico from "../layouts/LayoutPublico.astro";
import Header from "../components/Header.astro";
import ContadorPersonas from "../components/ContadorPersonas.astro";
import TarjetaRefugio from "../components/TarjetaRefugio.astro";
import ListaNecesidades from "../components/ListaNecesidades.astro";
import ListaNoticias from "../components/ListaNoticias.astro";
import { supabase } from "../lib/supabaseClient";

let refugios: any[] = [];
let necesidades: any[] = [];
let noticias: any[] = [];

try {
  const r1 = await supabase.from("refugios").select("*").eq("activo", true).order("nombre");
  if (!r1.error && r1.data) refugios = r1.data;
  const r2 = await supabase.from("necesidades").select("id, nombre, prioridad").eq("activo", true).order("prioridad");
  if (!r2.error && r2.data) necesidades = r2.data;
  const r3 = await supabase.from("noticias").select("id, titulo, contenido, created_at").order("created_at", { ascending: false }).limit(5);
  if (!r3.error && r3.data) noticias = r3.data;
} catch (_) {}
---

<LayoutPublico
  title="SOS La Victoria — Ayuda humanitaria para damnificados del río Arauca"
  description="Registro y consulta de personas afectadas por el desbordamiento del río Arauca en La Victoria, Apure, Venezuela. Refugios activos, necesidades urgentes y noticias."
>
  <Header />
  <main class="max-w-lg mx-auto px-4 py-6 space-y-5 pb-10">
    <div class="text-center">
      <h1 class="text-2xl sm:text-3xl font-extrabold text-red-700 tracking-tight leading-tight">
        ¿Eres damnificado por la inundación del río Arauca?
      </h1>
      <p class="text-base text-gray-600 mt-2">
        Regístrate aquí para recibir ayuda humanitaria y mantener informados a tus familiares.
      </p>
    </div>

    <ContadorPersonas />

    <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-center">
      <p class="text-red-800 font-semibold text-sm sm:text-base">Registra tus datos para acceder a refugios, alimentos y asistencia.</p>
      <p class="text-red-600 text-xs sm:text-sm mt-1">Tus familiares tambi&eacute;n pueden consultar tu estado.</p>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <a href="/registrar" class="flex flex-col items-center gap-2 bg-red-700 text-white rounded-2xl p-5 shadow-md hover:bg-red-800 transition">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
        <span class="font-bold text-sm">Registrar Persona</span>
      </a>
      <a href="/consultar" class="flex flex-col items-center gap-2 bg-blue-600 text-white rounded-2xl p-5 shadow-md hover:bg-blue-700 transition">
        <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <span class="font-bold text-sm">Consultar Persona</span>
      </a>
    </div>

    <!-- Refugios uno tras otro -->
    {refugios.length > 0 ? (
      <div>
        <h2 class="text-lg font-bold text-gray-800 mb-3">Puntos de Interés / Refugios</h2>
        <div class="space-y-3">
          {refugios.map(r => (
            <TarjetaRefugio nombre={r.nombre} direccion={r.direccion} ocupacion={r.ocupacion} capacidad={r.capacidad} latitud={r.latitud} longitud={r.longitud} />
          ))}
        </div>
      </div>
    ) : null}

    <ListaNecesidades necesidades={necesidades} />
    <ListaNoticias noticias={noticias} />

    <footer class="text-center text-xs text-gray-400 pt-4 border-t border-gray-200">
      <p>SOS La Victoria &mdash; Ayuda humanitaria para los afectados por el desbordamiento del río Arauca</p>
    </footer>
  </main>
</LayoutPublico>
