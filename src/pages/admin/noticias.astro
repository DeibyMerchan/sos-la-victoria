---
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
import { supabase } from "../../lib/supabaseClient";

if (Astro.request.method === "POST") {
  const fd = await Astro.request.formData();
  const action = fd.get("_action") as string;
  if (action === "create") { const t = (fd.get("titulo") as string).trim(); const c = (fd.get("contenido") as string).trim(); if (t && c) await supabase.from("noticias").insert({ titulo: t, contenido: c }); }
  else if (action === "delete") { const id = fd.get("id") as string; if (id) await supabase.from("noticias").delete().eq("id", id); }
  return Astro.redirect("/admin/noticias");
}

let noticias: any[] = [];
try { const { data } = await supabase.from("noticias").select("*").order("created_at", { ascending: false }); if (data) noticias = data; } catch (_) {}
---

<LayoutAdmin>
  <h1 class="text-2xl font-bold text-gray-800 mb-6">Noticias</h1>
  <form method="POST" class="bg-white rounded-xl shadow p-5 mb-6 space-y-4">
    <input type="hidden" name="_action" value="create" />
    <h2 class="font-semibold text-gray-700">Nueva noticia</h2>
    <div><label class="block text-xs text-gray-500 mb-1">Título *</label><input type="text" name="titulo" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none" /></div>
    <div><label class="block text-xs text-gray-500 mb-1">Contenido *</label><textarea name="contenido" required rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none resize-none"></textarea></div>
    <button type="submit" class="bg-red-700 text-white px-6 py-2 rounded-lg text-sm hover:bg-red-800">Publicar</button>
  </form>
  <div class="space-y-4">
    {noticias.length === 0 ? <p class="text-center text-gray-400 py-8">No hay noticias.</p> : noticias.map((n: any) => (
      <div class="bg-white rounded-xl shadow p-4 flex items-start justify-between gap-4">
        <div>
          <h3 class="font-semibold">{n.titulo}</h3>
          <p class="text-xs text-gray-400 mt-1">{new Date(n.created_at).toLocaleDateString("es-VE", { day: "numeric", month: "long", year: "numeric" })}</p>
          <p class="text-sm text-gray-600 mt-2">{n.contenido}</p>
        </div>
        <form method="POST" onsubmit="return confirm('¿Eliminar?')"><input type="hidden" name="_action" value="delete" /><input type="hidden" name="id" value={n.id} /><button class="text-red-500 text-xs font-medium">Eliminar</button></form>
      </div>
    ))}
  </div>
</LayoutAdmin>
