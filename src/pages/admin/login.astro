---
import LayoutPublico from "../../layouts/LayoutPublico.astro";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const email = formData.get("email") as string;
  const password = formData.get("password") as string;

  const { supabase } = await import("../../lib/supabaseClient");
  const { data, error } = await supabase.auth.signInWithPassword({ email, password });

  if (error || !data.session) {
    return new Response(
      JSON.stringify({ error: error?.message || "Credenciales inválidas" }),
      { status: 401, headers: { "Content-Type": "application/json" } }
    );
  }

  Astro.cookies.set("sb-access-token", data.session.access_token, {
    path: "/",
    httpOnly: true,
    secure: true,
    sameSite: "lax",
    maxAge: data.session.expires_in,
  });
  Astro.cookies.set("sb-refresh-token", data.session.refresh_token, {
    path: "/",
    httpOnly: true,
    secure: true,
    sameSite: "lax",
    maxAge: 60 * 60 * 24 * 30, // 30 days
  });

  return Astro.redirect("/admin");
}
---

<LayoutPublico>
  <main class="min-h-screen flex items-center justify-center bg-gray-100 px-4">
    <div class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-sm">
      <h1 class="text-2xl font-bold text-center text-red-700 mb-6">Admin — SOS La Victoria</h1>
      <form method="POST" class="space-y-4" id="login-form">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Correo</label>
          <input
            type="email"
            name="email"
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition"
            placeholder="admin@ejemplo.com"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Contraseña</label>
          <input
            type="password"
            name="password"
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition"
            placeholder="••••••••"
          />
        </div>
        <div id="login-error" class="hidden bg-red-50 text-red-700 text-sm rounded-xl p-3"></div>
        <button
          type="submit"
          class="w-full bg-red-700 text-white font-bold py-3 rounded-xl hover:bg-red-800 transition-colors"
        >
          Iniciar sesión
        </button>
      </form>
    </div>
  </main>
</LayoutPublico>

<script>
  const form = document.getElementById("login-form");
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(form as HTMLFormElement);
    const resp = await fetch(window.location.href, {
      method: "POST",
      body: fd,
    });
    if (resp.redirected) {
      window.location.href = resp.url;
    } else {
      const data = await resp.json();
      const errEl = document.getElementById("login-error");
      if (errEl) {
        errEl.textContent = data.error || "Error al iniciar sesión";
        errEl.classList.remove("hidden");
      }
    }
  });
</script>
