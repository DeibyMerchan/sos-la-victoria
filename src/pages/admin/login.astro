---
import LayoutPublico from "../../layouts/LayoutPublico.astro";

if (Astro.request.method === "POST") {
  const fd = await Astro.request.formData();
  const email = fd.get("email") as string;
  const password = fd.get("password") as string;
  const { supabase } = await import("../../lib/supabaseClient");
  const { data, error } = await supabase.auth.signInWithPassword({ email, password });

  if (error || !data.session) {
    return Astro.redirect("/admin/login?error=" + encodeURIComponent(error?.message || "Credenciales inválidas"));
  }

  const isProd = import.meta.env.PROD;
  Astro.cookies.set("sb-access-token", data.session.access_token, { path: "/", httpOnly: true, secure: isProd, sameSite: "lax", maxAge: 3600 });
  Astro.cookies.set("sb-refresh-token", data.session.refresh_token!, { path: "/", httpOnly: true, secure: isProd, sameSite: "lax", maxAge: 2592000 });
  return Astro.redirect("/admin");
}

const errorMsg = Astro.url.searchParams.get("error") || "";
---

<LayoutPublico>
  <main class="min-h-screen flex items-center justify-center bg-gray-100 px-4">
    <div class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-sm">
      <h1 class="text-2xl font-bold text-center text-red-700 mb-6">Admin — SOS La Victoria</h1>
      <form method="POST" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Correo</label>
          <input type="email" name="email" required class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none" placeholder="admin@ejemplo.com" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Contraseña</label>
          <input type="password" name="password" required class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none" placeholder="••••••••" />
        </div>
        {errorMsg && <div class="bg-red-50 text-red-700 text-sm rounded-xl p-3">{errorMsg}</div>}
        <button type="submit" class="w-full bg-red-700 text-white font-bold py-3 rounded-xl hover:bg-red-800 transition">Iniciar sesión</button>
      </form>
    </div>
  </main>
</LayoutPublico>
