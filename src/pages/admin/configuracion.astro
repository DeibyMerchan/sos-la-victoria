---
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
import { supabase } from "../../lib/supabaseClient";

if (Astro.request.method === "POST") {
  const fd = await Astro.request.formData();
  await supabase.from("configuracion").update({
    contador_visible: fd.get("contador_visible") === "on",
    whatsapp: (fd.get("whatsapp") as string).trim() || null,
    telefono: (fd.get("telefono") as string).trim() || null,
    refugio_principal_id: (fd.get("refugio_principal_id") as string) || null,
  }).eq("id", 1);
  return Astro.redirect("/admin/configuracion");
}

let config: any = {};
let refugios: any[] = [];
try {
  const r1 = await supabase.from("configuracion").select("*").eq("id", 1).maybeSingle();
  if (r1.data) config = r1.data;
  const r2 = await supabase.from("refugios").select("id, nombre").eq("activo", true).order("nombre");
  if (r2.data) refugios = r2.data;
} catch (_) {}
---

<LayoutAdmin>
  <h1 class="text-2xl font-bold text-gray-800 mb-6">Configuración</h1>
  <form method="POST" class="bg-white rounded-xl shadow p-6 space-y-5 max-w-xl">
    <label class="flex items-center gap-3"><input type="checkbox" name="contador_visible" checked={config.contador_visible !== false} class="rounded border-gray-300 text-red-600" /><span class="text-sm font-medium text-gray-700">Mostrar contador en inicio</span></label>
    <div><label class="block text-sm font-medium text-gray-700 mb-1">WhatsApp</label><input type="text" name="whatsapp" value={config.whatsapp || ""} class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none" placeholder="+584121234567" /></div>
    <div><label class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label><input type="text" name="telefono" value={config.telefono || ""} class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none" placeholder="+584121234567" /></div>
    <div><label class="block text-sm font-medium text-gray-700 mb-1">Refugio principal</label><select name="refugio_principal_id" class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm bg-white"><option value="">Ninguno</option>{refugios.map((r: any) => <option value={r.id} selected={config.refugio_principal_id === r.id}>{r.nombre}</option>)}</select></div>
    <button type="submit" class="bg-red-700 text-white px-6 py-2.5 rounded-xl text-sm hover:bg-red-800">Guardar</button>
  </form>
</LayoutAdmin>
