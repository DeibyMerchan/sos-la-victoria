---
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
import { createSupabaseAdmin } from "../../lib/supabaseAdmin";
const supabaseAdmin = createSupabaseAdmin();

let personas = 0; let refugios = 0; let noticias = 0; let sosPend = 0;
let enVivienda = 0; let evacuados = 0; let enRefugio = 0;
let perdidaTotal = 0; let perdidaParcial = 0; let danosMayores = 0; let danosMenores = 0; let sinAfectacion = 0;
let totalAcompanantes = 0; let totalEnRefugios = 0; let acompEnRefugios = 0; let recientes24h = 0;

try {
  const [
    r1, r2, r3, r4,
    r5, r6, r7,
    r8, r9, r10, r11, r12,
    r13, r14, r15,
  ] = await Promise.all([
    supabaseAdmin.from("personas").select("id", { count: "exact", head: true }),
    supabaseAdmin.from("refugios").select("id", { count: "exact", head: true }),
    supabaseAdmin.from("noticias").select("id", { count: "exact", head: true }),
    supabaseAdmin.from("solicitudes_sos").select("id", { count: "exact", head: true }).eq("atendido", false),
    supabaseAdmin.from("personas").select("id", { count: "exact", head: true }).eq("estado", "en_vivienda"),
    supabaseAdmin.from("personas").select("id", { count: "exact", head: true }).eq("estado", "evacuado"),
    supabaseAdmin.from("personas").select("id", { count: "exact", head: true }).eq("estado", "en_refugio"),
    supabaseAdmin.from("personas").select("id", { count: "exact", head: true }).eq("nivel_afectacion", "perdida_total"),
    supabaseAdmin.from("personas").select("id", { count: "exact", head: true }).eq("nivel_afectacion", "perdida_parcial"),
    supabaseAdmin.from("personas").select("id", { count: "exact", head: true }).eq("nivel_afectacion", "danos_mayores"),
    supabaseAdmin.from("personas").select("id", { count: "exact", head: true }).eq("nivel_afectacion", "danos_menores"),
    supabaseAdmin.from("personas").select("id", { count: "exact", head: true }).eq("nivel_afectacion", "sin_afectacion"),
    supabaseAdmin.from("personas").select("acompanantes").eq("estado", "en_refugio"),
    supabaseAdmin.from("personas").select("acompanantes"),
    supabaseAdmin.from("personas").select("id", { count: "exact", head: true }).gte("created_at", new Date(Date.now() - 86400000).toISOString()),
  ]);

  if (r1.count != null) personas = r1.count;
  if (r2.count != null) refugios = r2.count;
  if (r3.count != null) noticias = r3.count;
  if (r4.count != null) sosPend = r4.count;
  if (r5.count != null) enVivienda = r5.count;
  if (r6.count != null) evacuados = r6.count;
  if (r7.count != null) enRefugio = r7.count;
  if (r8.count != null) perdidaTotal = r8.count;
  if (r9.count != null) perdidaParcial = r9.count;
  if (r10.count != null) danosMayores = r10.count;
  if (r11.count != null) danosMenores = r11.count;
  if (r12.count != null) sinAfectacion = r12.count;
  if (r13.data) {
    acompEnRefugios = r13.data.reduce((s: number, p: any) => s + (p.acompanantes || 0), 0);
    totalEnRefugios = r13.data.length + acompEnRefugios;
  }
  if (r14.data) totalAcompanantes = r14.data.reduce((s: number, p: any) => s + (p.acompanantes || 0), 0);
  if (r15.count != null) recientes24h = r15.count;
} catch (_) {}

const afectacionLabels: Record<string, string> = {
  perdida_total: "Pérdida total", perdida_parcial: "Pérdida parcial",
  danos_mayores: "Daños mayores", danos_menores: "Daños menores", sin_afectacion: "Sin afectación",
};
---

<LayoutAdmin>
  <h1 class="text-2xl font-bold text-gray-800 mb-6">Dashboard</h1>

  <!-- Totales rápidos -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl shadow-md p-5"><p class="text-sm text-gray-500">Personas</p><p class="text-3xl font-extrabold text-gray-800">{personas}</p></div>
    <div class="bg-white rounded-xl shadow-md p-5"><p class="text-sm text-gray-500">Refugios</p><p class="text-3xl font-extrabold text-gray-800">{refugios}</p></div>
    <div class="bg-white rounded-xl shadow-md p-5"><p class="text-sm text-gray-500">Noticias</p><p class="text-3xl font-extrabold text-gray-800">{noticias}</p></div>
    <a href="/admin/sos" class="bg-white rounded-xl shadow-md p-5 hover:shadow-lg transition">
      <p class="text-sm text-gray-500">SOS pendientes</p>
      <p class="text-3xl font-extrabold text-red-600">{sosPend}</p>
    </a>
  </div>

  <!-- Resumen detallado -->
  <h2 class="text-lg font-bold text-gray-700 mb-4">Resumen de afectaci&oacute;n</h2>

  <!-- Por situación -->
  <div class="bg-white rounded-xl shadow-md p-5 mb-4">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Por situaci&oacute;n actual</h3>
    <div class="grid grid-cols-3 gap-4 text-center">
      <div class="bg-blue-50 rounded-lg p-3">
        <p class="text-2xl font-extrabold text-blue-700">{enVivienda}</p>
        <p class="text-xs text-blue-600 mt-1">En vivienda</p>
      </div>
      <div class="bg-orange-50 rounded-lg p-3">
        <p class="text-2xl font-extrabold text-orange-700">{evacuados}</p>
        <p class="text-xs text-orange-600 mt-1">Evacuados</p>
      </div>
      <div class="bg-emerald-50 rounded-lg p-3">
        <p class="text-2xl font-extrabold text-emerald-700">{enRefugio}</p>
        <p class="text-xs text-emerald-600 mt-1">En refugio</p>
      </div>
    </div>
    {enRefugio > 0 && (
      <p class="text-xs text-gray-500 mt-3">
        {totalEnRefugios} personas en refugios (incluyendo {acompEnRefugios} acompañantes)
      </p>
    )}
  </div>

  <!-- Por nivel de afectación -->
  <div class="bg-white rounded-xl shadow-md p-5 mb-4">
    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-3">Por nivel de afectaci&oacute;n</h3>
    <div class="space-y-2">
      {[
        { k: "perdida_total", v: perdidaTotal, bar: "bg-red-500", text: "text-red-700" },
        { k: "perdida_parcial", v: perdidaParcial, bar: "bg-orange-500", text: "text-orange-700" },
        { k: "danos_mayores", v: danosMayores, bar: "bg-yellow-500", text: "text-yellow-700" },
        { k: "danos_menores", v: danosMenores, bar: "bg-blue-500", text: "text-blue-700" },
        { k: "sin_afectacion", v: sinAfectacion, bar: "bg-gray-400", text: "text-gray-600" },
      ].map(item => (
        <div class="flex items-center gap-2">
          <span class="text-xs font-medium w-28 text-right text-gray-600">{afectacionLabels[item.k]}</span>
          <div class="flex-1 bg-gray-100 rounded-full h-4 overflow-hidden">
            <div class={`${item.bar} h-full rounded-full transition-all`} style={`width: ${personas ? (item.v / personas) * 100 : 0}%`}></div>
          </div>
          <span class={`text-xs font-bold w-8 ${item.text}`}>{item.v}</span>
        </div>
      ))}
    </div>
    <p class="text-xs text-gray-400 mt-3">
      {personas - perdidaTotal - perdidaParcial - danosMayores - danosMenores - sinAfectacion} persona{personas - perdidaTotal - perdidaParcial - danosMayores - danosMenores - sinAfectacion !== 1 ? "s" : ""} sin clasificar
    </p>
  </div>

  <!-- Datos adicionales -->
  <div class="grid grid-cols-2 gap-4 mb-8">
    <div class="bg-white rounded-xl shadow-md p-4">
      <p class="text-xs text-gray-500">Total acompa&ntilde;antes</p>
      <p class="text-2xl font-extrabold text-gray-800">{totalAcompanantes}</p>
    </div>
    <div class="bg-white rounded-xl shadow-md p-4">
      <p class="text-xs text-gray-500">&Uacute;ltimas 24 horas</p>
      <p class="text-2xl font-extrabold text-emerald-600">{recientes24h}</p>
    </div>
  </div>

  <!-- Accesos rápidos -->
  <div class="mt-8 grid grid-cols-2 lg:grid-cols-6 gap-3">
    <a href="/admin/personas" class="bg-white rounded-xl shadow-md p-4 text-center text-sm font-medium text-gray-700 hover:text-red-700">Personas</a>
    <a href="/admin/refugios" class="bg-white rounded-xl shadow-md p-4 text-center text-sm font-medium text-gray-700 hover:text-red-700">Refugios</a>
    <a href="/admin/necesidades" class="bg-white rounded-xl shadow-md p-4 text-center text-sm font-medium text-gray-700 hover:text-red-700">Necesidades</a>
    <a href="/admin/noticias" class="bg-white rounded-xl shadow-md p-4 text-center text-sm font-medium text-gray-700 hover:text-red-700">Noticias</a>
    <a href="/admin/sos" class="bg-white rounded-xl shadow-md p-4 text-center text-sm font-medium text-gray-700 hover:text-red-700">SOS</a>
    <a href="/admin/configuracion" class="bg-white rounded-xl shadow-md p-4 text-center text-sm font-medium text-gray-700 hover:text-red-700">Configuración</a>
  </div>
</LayoutAdmin>
