---
import LayoutAdmin from "../../layouts/LayoutAdmin.astro";
import { supabase } from "../../lib/supabaseClient";

const { count: totalPersonas } = await supabase
  .from("personas")
  .select("id", { count: "exact", head: true });

const { count: totalRefugios } = await supabase
  .from("refugios")
  .select("id", { count: "exact", head: true });

const { count: totalNoticias } = await supabase
  .from("noticias")
  .select("id", { count: "exact", head: true });

const { count: sosSinAtender } = await supabase
  .from("solicitudes_sos")
  .select("id", { count: "exact", head: true })
  .eq("atendido", false);
---

<LayoutAdmin>
  <h1 class="text-2xl font-bold text-gray-800 mb-6">Dashboard</h1>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <!-- Personas -->
    <div class="bg-white rounded-xl shadow-md p-5">
      <div class="flex items-center gap-3 mb-2">
        <div class="bg-blue-100 p-2.5 rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
        </div>
        <p class="text-sm text-gray-500">Personas</p>
      </div>
      <p class="text-3xl font-extrabold text-gray-800">{totalPersonas ?? 0}</p>
    </div>

    <!-- Refugios -->
    <div class="bg-white rounded-xl shadow-md p-5">
      <div class="flex items-center gap-3 mb-2">
        <div class="bg-emerald-100 p-2.5 rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <p class="text-sm text-gray-500">Refugios</p>
      </div>
      <p class="text-3xl font-extrabold text-gray-800">{totalRefugios ?? 0}</p>
    </div>

    <!-- Noticias -->
    <div class="bg-white rounded-xl shadow-md p-5">
      <div class="flex items-center gap-3 mb-2">
        <div class="bg-purple-100 p-2.5 rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
          </svg>
        </div>
        <p class="text-sm text-gray-500">Noticias</p>
      </div>
      <p class="text-3xl font-extrabold text-gray-800">{totalNoticias ?? 0}</p>
    </div>

    <!-- SOS sin atender -->
    <div class="bg-white rounded-xl shadow-md p-5">
      <div class="flex items-center gap-3 mb-2">
        <div class="bg-red-100 p-2.5 rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/>
          </svg>
        </div>
        <p class="text-sm text-gray-500">SOS pendientes</p>
      </div>
      <p class="text-3xl font-extrabold text-gray-800">{sosSinAtender ?? 0}</p>
    </div>
  </div>

  <!-- Enlaces rápidos -->
  <div class="mt-8 grid grid-cols-2 lg:grid-cols-5 gap-3">
    <a href="/admin/personas" class="bg-white rounded-xl shadow-md p-4 text-center hover:shadow-lg transition text-sm font-medium text-gray-700 hover:text-red-700">
      Ver personas
    </a>
    <a href="/admin/refugios" class="bg-white rounded-xl shadow-md p-4 text-center hover:shadow-lg transition text-sm font-medium text-gray-700 hover:text-red-700">
      Gestionar refugios
    </a>
    <a href="/admin/necesidades" class="bg-white rounded-xl shadow-md p-4 text-center hover:shadow-lg transition text-sm font-medium text-gray-700 hover:text-red-700">
      Necesidades
    </a>
    <a href="/admin/noticias" class="bg-white rounded-xl shadow-md p-4 text-center hover:shadow-lg transition text-sm font-medium text-gray-700 hover:text-red-700">
      Noticias
    </a>
    <a href="/admin/configuracion" class="bg-white rounded-xl shadow-md p-4 text-center hover:shadow-lg transition text-sm font-medium text-gray-700 hover:text-red-700">
      Configuración
    </a>
  </div>
</LayoutAdmin>
