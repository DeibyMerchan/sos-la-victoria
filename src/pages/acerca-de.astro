---
import LayoutPublico from "../layouts/LayoutPublico.astro";
import Header from "../components/Header.astro";
---

<LayoutPublico
  title="Acerca de SOS La Victoria"
  description="SOS La Victoria es una aplicación de ayuda humanitaria para los afectados por el desbordamiento del río Arauca en La Victoria, parroquia Urdaneta, municipio Páez, Apure, Venezuela."
>
  <Header />
  <main class="max-w-lg mx-auto px-4 py-6 pb-10">
    <h1 class="text-2xl font-bold text-red-700 mb-4">Acerca de</h1>
    <div class="bg-white rounded-2xl shadow-md p-5 space-y-3 text-gray-700 text-sm leading-relaxed">
      <p><strong>SOS La Victoria</strong> es una aplicación creada para apoyar la gestión humanitaria tras el desbordamiento del río Arauca en La Victoria, parroquia Urdaneta, municipio Páez, estado Apure, Venezuela.</p>
      <p>Permite registrar personas afectadas, consultar su estado, ubicar refugios disponibles, conocer necesidades urgentes y solicitar asistencia de emergencia.</p>
      <p class="text-xs text-gray-400 pt-2">Versión 1.0 &mdash; Julio 2026</p>
    </div>
  </main>
</LayoutPublico>
