---
import LayoutPublico from "../layouts/LayoutPublico.astro";
import Header from "../components/Header.astro";
---

<LayoutPublico>
  <Header />
  <main class="max-w-lg mx-auto px-4 py-6 pb-10">
    <a href="/" class="text-red-600 text-sm font-medium inline-flex items-center gap-1 mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Volver
    </a>

    <h1 class="text-2xl font-bold text-red-700 mb-1">Consultar Persona</h1>
    <p class="text-sm text-gray-500 mb-6">Busque una persona por cédula, nombre o apellido</p>

    <div class="bg-white rounded-2xl shadow-md p-5 space-y-4">
      <div>
        <input
          type="text"
          id="termino"
          class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition"
          placeholder="Cédula, nombre o apellido..."
          autocomplete="off"
        />
      </div>
      <button
        id="btn-buscar"
        class="w-full bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 transition-colors shadow-md"
      >
        Buscar
      </button>
    </div>

    <div id="resultados" class="mt-4 space-y-3">
      <!-- Los resultados aparecen aquí -->
    </div>

    <div id="estado-vacio" class="mt-12 text-center text-gray-400 hidden">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <p>No se encontraron registros con ese criterio.</p>
    </div>

    <div id="cargando" class="mt-12 text-center text-gray-400 hidden">
      <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-red-700 mx-auto mb-3"></div>
      <p>Buscando...</p>
    </div>
  </main>
</LayoutPublico>

<script>
  import { supabase } from "../lib/supabaseClient";

  const estadoLabel: Record<string, string> = {
    en_vivienda: "En su vivienda",
    evacuado: "Evacuado",
    en_refugio: "En refugio",
  };

  const estadoColor: Record<string, string> = {
    en_vivienda: "bg-blue-100 text-blue-800",
    evacuado: "bg-orange-100 text-orange-800",
    en_refugio: "bg-emerald-100 text-emerald-800",
  };

  async function buscar() {
    const termino = (document.getElementById("termino") as HTMLInputElement).value.trim();
    if (!termino) return;

    const resultadosEl = document.getElementById("resultados")!;
    const vacioEl = document.getElementById("estado-vacio")!;
    const cargandoEl = document.getElementById("cargando")!;

    resultadosEl.innerHTML = "";
    vacioEl.classList.add("hidden");
    cargandoEl.classList.remove("hidden");

    const { data, error } = await supabase.rpc("buscar_persona", { termino });

    cargandoEl.classList.add("hidden");

    if (error) {
      resultadosEl.innerHTML = `<div class="bg-red-50 text-red-700 rounded-xl p-4 text-sm">Error: ${error.message}</div>`;
      return;
    }

    if (!data || data.length === 0) {
      vacioEl.classList.remove("hidden");
      return;
    }

    resultadosEl.innerHTML = data
      .map(
        (p: any) => `
        <div class="bg-white rounded-2xl shadow-md p-4">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="font-bold text-gray-800">${p.nombres} ${p.apellidos}</h3>
              <p class="text-xs text-gray-500 mt-0.5">C.I: ${p.cedula.startsWith("SINCED-") ? "(Sin cédula)" : p.cedula}</p>
              ${p.refugio_nombre ? `<p class="text-xs text-gray-500">Refugio: ${p.refugio_nombre}</p>` : ""}
            </div>
            <span class="text-xs font-medium px-2.5 py-1 rounded-full ${estadoColor[p.estado] || "bg-gray-100 text-gray-600"}">
              ${estadoLabel[p.estado] || p.estado}
            </span>
          </div>
          <p class="text-xs text-gray-400 mt-2">
            Registrado: ${new Date(p.created_at).toLocaleDateString("es-VE", { day: "numeric", month: "short", year: "numeric", hour: "2-digit", minute: "2-digit" })}
          </p>
        </div>
      `
      )
      .join("");
  }

  document.getElementById("btn-buscar")?.addEventListener("click", buscar);
  document.getElementById("termino")?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") buscar();
  });
</script>
