---
import LayoutPublico from "../layouts/LayoutPublico.astro";
import Header from "../components/Header.astro";
---

<LayoutPublico
  title="Consultar Persona | SOS La Victoria"
  description="Busque personas registradas por cédula, nombre o apellido. Consulte el estado actual y la ubicación de damnificados del río Arauca."
>
  <Header />
  <main class="max-w-lg mx-auto px-4 py-6 pb-10">
    <a href="/" class="text-red-600 text-sm font-medium inline-flex items-center gap-1 mb-4 hover:underline">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg> Volver
    </a>
    <h1 class="text-2xl font-bold text-red-700 mb-1">Consultar Persona</h1>
    <p class="text-sm text-gray-500 mb-6">Busque por cédula, nombre o apellido</p>

    <div class="bg-white rounded-2xl shadow-md p-5 space-y-4">
      <input type="text" id="termino" class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none" placeholder="Cédula, nombre o apellido..." />
      <button id="btn-buscar" class="w-full bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 transition">Buscar</button>
    </div>
    <div id="resultados" class="mt-4 space-y-3"></div>
    <div id="cargando" class="mt-12 text-center text-gray-400 hidden"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-red-700 mx-auto mb-3"></div><p>Buscando...</p></div>
    <div id="vacio" class="mt-12 text-center text-gray-400 hidden"><p>No se encontraron registros.</p></div>
  </main>
</LayoutPublico>

<script>
  import { supabase } from "../lib/supabaseClient";

  const labels: Record<string, string> = { en_vivienda: "En su vivienda", evacuado: "Evacuado", en_refugio: "En refugio" };
  const colors: Record<string, string> = { en_vivienda: "bg-blue-100 text-blue-800", evacuado: "bg-orange-100 text-orange-800", en_refugio: "bg-emerald-100 text-emerald-800" };

  async function buscar() {
    const t = (document.getElementById("termino") as HTMLInputElement).value.trim();
    if (!t) return;
    const res = document.getElementById("resultados")!;
    const vac = document.getElementById("vacio")!;
    const load = document.getElementById("cargando")!;
    res.innerHTML = ""; vac.classList.add("hidden"); load.classList.remove("hidden");

    const { data, error } = await supabase.rpc("buscar_persona", { termino: t });
    load.classList.add("hidden");
    if (error || !data?.length) { vac.classList.remove("hidden"); return; }

    res.innerHTML = data.map((p: any) => `
      <div class="bg-white rounded-2xl shadow-md p-4">
        <div class="flex items-start justify-between">
          <div>
            <h3 class="font-bold text-gray-800">${p.nombres} ${p.apellidos}</h3>
            <p class="text-xs text-gray-500">C.I: ${p.cedula.startsWith("SINCED-") ? "(Sin cédula)" : p.cedula}</p>
            ${p.refugio_nombre ? `<p class="text-xs text-gray-500">Refugio: ${p.refugio_nombre}</p>` : ""}
          </div>
          <span class="text-xs font-medium px-2.5 py-1 rounded-full ${colors[p.estado] || "bg-gray-100"}">${labels[p.estado] || p.estado}</span>
        </div>
        <p class="text-xs text-gray-400 mt-2">Registrado: ${new Date(p.created_at).toLocaleDateString("es-VE", { day: "numeric", month: "short", year: "numeric" })}</p>
      </div>
    `).join("");
  }

  document.getElementById("btn-buscar")?.addEventListener("click", buscar);
  document.getElementById("termino")?.addEventListener("keydown", (e) => { if (e.key === "Enter") buscar(); });
</script>
