---
import LayoutPublico from "../layouts/LayoutPublico.astro";
import Header from "../components/Header.astro";
import TarjetaRefugio from "../components/TarjetaRefugio.astro";
import { supabase } from "../lib/supabaseClient";

let refugios: any[] = [];
try { const { data } = await supabase.from("refugios").select("*").eq("activo", true).order("nombre"); if (data) refugios = data; } catch (_) {}
---

<LayoutPublico
  title="Refugios Disponibles | SOS La Victoria"
  description="Refugios activos para damnificados en La Victoria, Apure. Consulte ubicación, capacidad y ocupación de cada centro de acogida."
>
  <Header />
  <main class="max-w-lg mx-auto px-4 py-6 pb-10">
    <a href="/" class="text-red-600 text-sm font-medium inline-flex items-center gap-1 mb-4 hover:underline">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg> Volver
    </a>
    <h1 class="text-2xl font-bold text-red-700 mb-6">Refugios</h1>
    {refugios.length === 0 ? <p class="text-center text-gray-400 py-8">No hay refugios activos.</p> : (
      <div class="space-y-3">
        {refugios.map(r => <TarjetaRefugio nombre={r.nombre} direccion={r.direccion} ocupacion={r.ocupacion} capacidad={r.capacidad} latitud={r.latitud} longitud={r.longitud} />)}
      </div>
    )}
  </main>
</LayoutPublico>
