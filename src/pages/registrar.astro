---
import LayoutPublico from "../layouts/LayoutPublico.astro";
import Header from "../components/Header.astro";
import { supabase } from "../lib/supabaseClient";

const { data: refugios } = await supabase
  .from("refugios")
  .select("id, nombre")
  .eq("activo", true)
  .order("nombre");
---

<LayoutPublico>
  <Header />
  <main class="max-w-lg mx-auto px-4 py-6 pb-10">
    <a href="/" class="text-red-600 text-sm font-medium inline-flex items-center gap-1 mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Volver
    </a>

    <h1 class="text-2xl font-bold text-red-700 mb-1">Registrar Persona</h1>
    <p class="text-sm text-gray-500 mb-6">Complete los datos de la persona afectada</p>

    <form id="form-registro" class="space-y-4 bg-white rounded-2xl shadow-md p-5" autocomplete="off">
      <!-- Cédula -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Cédula de identidad *</label>
        <input
          type="text"
          id="cedula"
          name="cedula"
          inputmode="numeric"
          maxlength="10"
          class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition"
          placeholder="Ej: 18456321"
        />
        <div class="flex items-center gap-2 mt-2">
          <input type="checkbox" id="sin-cedula" class="rounded border-gray-300 text-red-600 focus:ring-red-500" />
          <label for="sin-cedula" class="text-xs text-gray-500">No tiene cédula a mano</label>
        </div>
        <p id="cedula-aviso" class="text-xs text-orange-600 mt-1 hidden"></p>
      </div>

      <!-- Nombres -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Nombres *</label>
        <input
          type="text"
          id="nombres"
          name="nombres"
          class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition"
          placeholder="Nombres completos"
        />
      </div>

      <!-- Apellidos -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Apellidos *</label>
        <input
          type="text"
          id="apellidos"
          name="apellidos"
          class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition"
          placeholder="Apellidos completos"
        />
      </div>

      <!-- Teléfono -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
        <input
          type="tel"
          id="telefono"
          name="telefono"
          class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition"
          placeholder="Ej: 0412-1234567"
        />
      </div>

      <!-- Sector y Dirección -->
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Sector</label>
          <input
            type="text"
            id="sector"
            name="sector"
            class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition"
            placeholder="Sector"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
          <input
            type="text"
            id="direccion"
            name="direccion"
            class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition"
            placeholder="Dirección"
          />
        </div>
      </div>

      <!-- Acompañantes -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Número de acompañantes</label>
        <input
          type="number"
          id="acompanantes"
          name="acompanantes"
          min="0"
          max="99"
          value="0"
          class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition"
        />
      </div>

      <!-- Estado -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Situación actual *</label>
        <select
          id="estado"
          name="estado"
          class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition bg-white"
        >
          <option value="en_vivienda">En su vivienda</option>
          <option value="evacuado">Evacuado (sin refugio asignado)</option>
          <option value="en_refugio">En refugio</option>
        </select>
      </div>

      <!-- Refugio (condicional) -->
      <div id="refugio-group" class="hidden">
        <label class="block text-sm font-medium text-gray-700 mb-1">Refugio</label>
        <select
          id="refugio_id"
          name="refugio_id"
          class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition bg-white"
        >
          <option value="">Seleccionar refugio</option>
          {refugios?.map((r) => (
            <option value={r.id}>{r.nombre}</option>
          ))}
        </select>
      </div>

      <!-- Observaciones -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Observaciones</label>
        <textarea
          id="observaciones"
          name="observaciones"
          rows="2"
          class="w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition resize-none"
          placeholder="Información adicional relevante"
        ></textarea>
      </div>

      <!-- Botón -->
      <button
        type="submit"
        id="btn-enviar"
        class="w-full bg-red-700 text-white font-bold py-3.5 rounded-xl hover:bg-red-800 transition-colors shadow-md disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Registrar persona
      </button>

      <!-- Mensajes -->
      <div id="msg-exito" class="hidden bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-xl p-3 text-sm">
        Persona registrada correctamente
      </div>
      <div id="msg-error" class="hidden bg-red-50 border border-red-200 text-red-800 rounded-xl p-3 text-sm"></div>
    </form>
  </main>
</LayoutPublico>

<script>
  import { supabase } from "../lib/supabaseClient";

  interface RegistroPayload {
    cedula: string;
    sin_cedula: boolean;
    nombres: string;
    apellidos: string;
    telefono: string;
    sector: string;
    direccion: string;
    acompanantes: number;
    estado: string;
    refugio_id: string | null;
    observaciones: string;
  }

  const COLA_KEY = "registros_pendientes";

  function getCola(): RegistroPayload[] {
    try {
      return JSON.parse(localStorage.getItem(COLA_KEY) || "[]");
    } catch {
      return [];
    }
  }

  function setCola(cola: RegistroPayload[]) {
    localStorage.setItem(COLA_KEY, JSON.stringify(cola));
  }

  function limpiarForm() {
    const form = document.getElementById("form-registro") as HTMLFormElement | null;
    form?.reset();
    document.getElementById("cedula-aviso")?.classList.add("hidden");
    const refEl = document.getElementById("refugio-group");
    if (refEl) refEl.classList.add("hidden");
    const sinCedula = document.getElementById("sin-cedula") as HTMLInputElement | null;
    if (sinCedula) sinCedula.checked = false;
  }

  function mostrarExito() {
    const el = document.getElementById("msg-exito");
    if (el) { el.classList.remove("hidden"); setTimeout(() => el.classList.add("hidden"), 5000); }
  }

  function mostrarError(msg: string) {
    const el = document.getElementById("msg-error");
    if (el) { el.classList.remove("hidden"); el.textContent = msg; setTimeout(() => el.classList.add("hidden"), 8000); }
  }

  async function verificarCedula(cedula: string) {
    const aviso = document.getElementById("cedula-aviso");
    const btnEnviar = document.getElementById("btn-enviar") as HTMLButtonElement | null;
    if (!cedula || cedula.length < 4) {
      if (aviso) aviso.classList.add("hidden");
      if (btnEnviar) btnEnviar.disabled = false;
      return;
    }

    const { data, error } = await supabase.rpc("existe_cedula", { c: cedula });

    if (error) return;

    if (data && data.length > 0) {
      const p = data[0] as { nombres: string; apellidos: string; estado: string; created_at: string };
      if (aviso) {
        aviso.textContent = `Esta persona ya fue registrada: ${p.nombres} ${p.apellidos} — ${p.estado} (${new Date(p.created_at).toLocaleDateString()})`;
        aviso.classList.remove("hidden");
      }
      if (btnEnviar) btnEnviar.disabled = true;
    } else {
      if (aviso) aviso.classList.add("hidden");
      if (btnEnviar) btnEnviar.disabled = false;
    }
  }

  // Mostrar/ocultar refugio según estado
  const estadoSelect = document.getElementById("estado") as HTMLSelectElement | null;
  const refugioGroup = document.getElementById("refugio-group");
  estadoSelect?.addEventListener("change", () => {
    if (refugioGroup && estadoSelect) {
      refugioGroup.classList.toggle("hidden", estadoSelect.value !== "en_refugio");
    }
  });

  // Verificar cédula al perder foco
  const cedulaInput = document.getElementById("cedula") as HTMLInputElement | null;
  cedulaInput?.addEventListener("blur", () => {
    const sinCedulaEl = document.getElementById("sin-cedula") as HTMLInputElement | null;
    const sinCedula = sinCedulaEl ? sinCedulaEl.checked : false;
    if (!sinCedula && cedulaInput) {
      verificarCedula(cedulaInput.value.trim());
    }
  });

  // Toggle sin cédula
  document.getElementById("sin-cedula")?.addEventListener("change", function (this: HTMLInputElement) {
    const checked = this.checked;
    if (cedulaInput) cedulaInput.disabled = checked;
    if (checked) {
      if (cedulaInput) cedulaInput.value = "";
      document.getElementById("cedula-aviso")?.classList.add("hidden");
      const btn = document.getElementById("btn-enviar") as HTMLButtonElement | null;
      if (btn) btn.disabled = false;
    }
  });

  // Enviar formulario
  document.getElementById("form-registro")?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);
    const sinCedulaEl = document.getElementById("sin-cedula") as HTMLInputElement | null;
    const sinCedula = sinCedulaEl ? sinCedulaEl.checked : false;

    let cedula = (fd.get("cedula") as string || "").trim();
    if (sinCedula) {
      cedula = "SINCED-" + Date.now();
    }

    if (!cedula) {
      mostrarError("La cédula es obligatoria.");
      return;
    }
    if (!sinCedula && !/^\d{5,10}$/.test(cedula.replace(/[^0-9]/g, ""))) {
      mostrarError("La cédula debe tener entre 5 y 10 dígitos numéricos.");
      return;
    }

    const nombres = (fd.get("nombres") as string || "").trim();
    const apellidos = (fd.get("apellidos") as string || "").trim();
    if (!nombres) { mostrarError("El nombre es obligatorio."); return; }
    if (!apellidos) { mostrarError("El apellido es obligatorio."); return; }

    const payload: RegistroPayload = {
      cedula,
      sin_cedula: sinCedula,
      nombres,
      apellidos,
      telefono: (fd.get("telefono") as string || "").trim(),
      sector: (fd.get("sector") as string || "").trim(),
      direccion: (fd.get("direccion") as string || "").trim(),
      acompanantes: parseInt(fd.get("acompanantes") as string) || 0,
      estado: (fd.get("estado") as string) || "",
      refugio_id: (fd.get("refugio_id") as string) || null,
      observaciones: (fd.get("observaciones") as string || "").trim(),
    };

    const { error } = await supabase.from("personas").insert({
      cedula: payload.cedula,
      sin_cedula: payload.sin_cedula,
      nombres: payload.nombres,
      apellidos: payload.apellidos,
      telefono: payload.telefono || null,
      sector: payload.sector || null,
      direccion: payload.direccion || null,
      acompanantes: payload.acompanantes,
      estado: payload.estado,
      refugio_id: payload.refugio_id || null,
      observaciones: payload.observaciones || null,
    });

    if (error) {
      if (!navigator.onLine) {
        const cola = getCola();
        cola.push(payload);
        setCola(cola);
        mostrarError("Sin conexión. El registro se guardó y se enviará automáticamente al reconectar.");
        limpiarForm();
      } else {
        mostrarError("Error: " + error.message);
      }
    } else {
      mostrarExito();
      limpiarForm();
    }
  });

  // Sincronizar cola pendiente al reconectar
  function sincronizarCola() {
    const cola = getCola();
    if (cola.length === 0) return;

    const pendientes = [...cola];
    setCola([]);

    Promise.all(
      pendientes.map((p) =>
        supabase.from("personas").insert({
          cedula: p.cedula,
          sin_cedula: p.sin_cedula,
          nombres: p.nombres,
          apellidos: p.apellidos,
          telefono: p.telefono || null,
          sector: p.sector || null,
          direccion: p.direccion || null,
          acompanantes: p.acompanantes,
          estado: p.estado,
          refugio_id: p.refugio_id || null,
          observaciones: p.observaciones || null,
        })
      )
    ).then((results) => {
      const fallidas = results.filter((r) => r.error);
      if (fallidas.length > 0) {
        const colaActual = getCola();
        colaActual.push(...pendientes);
        setCola(colaActual);
      }
    });
  }

  window.addEventListener("online", sincronizarCola);
  sincronizarCola();
</script>
